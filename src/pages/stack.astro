---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Stack | cl1nical">
  <main class="min-h-screen bg-[#030303] text-white p-8 pt-32 text-center">
    <div class="max-w-2xl mx-auto">
      <h1 class="text-6xl font-black tracking-tighter mb-4">THE_STACK</h1>
      <p class="text-gray-500 font-mono mb-12">// TOOLS_AND_INFRASTRUCTURE</p>
      
      <div class="flex flex-wrap justify-center gap-3">
        {["Astro 5", "Tailwind 4", "React 19", "Framer Motion", "TypeScript", "Docker", "Nginx", "Linux"].map((tool) => (
          <span class="px-4 py-2 rounded-lg bg-white/5 border border-white/10 text-sm font-medium hover:bg-white/10 transition-colors">
            {tool}
          </span>
        ))}
      </div>

      <div class="mt-16">
        <a href="/" class="px-8 py-3 bg-purple-600 rounded-full font-bold hover:bg-purple-500 transition-all">Back to Terminal</a>
      </div>
    </div>
  </main>
</Layout>