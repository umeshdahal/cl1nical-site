---
import AppLayout from '../layouts/AppLayout.astro';
import { createServerClient } from '../lib/supabase';
import { toAbsoluteUrl } from '../lib/site';

let error = '';
let email = '';

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  email = String(formData.get('email') ?? '').trim();
  const password = String(formData.get('password') ?? '');

  if (password.length < 8) {
    error = 'Password must be at least 8 characters.';
  } else {
    const supabase = createServerClient(Astro.cookies);
    const { data, error: signUpError } = await supabase.auth.signUp({
      email,
      password,
      options: {
        emailRedirectTo: toAbsoluteUrl('/auth/confirm'),
      },
    });

    if (signUpError) {
      error = signUpError.message;
    } else if (data.session) {
      return Astro.redirect('/dashboard');
    } else {
      return Astro.redirect('/login?message=check-email');
    }
  }
}
---

<AppLayout title="Register | cl1nical" description="Create your cl1nical account">
  <section class="relative flex min-h-screen items-center justify-center overflow-hidden px-4 py-12 sm:px-6">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_left,_rgba(232,160,32,0.16),_transparent_36%),radial-gradient(circle_at_bottom_right,_rgba(45,91,227,0.18),_transparent_34%)]"></div>

    <div class="relative w-full max-w-md rounded-[32px] border border-white/10 bg-white/6 p-8 shadow-[0_30px_120px_rgba(0,0,0,0.45)] backdrop-blur-xl sm:p-10">
      <div class="mb-8">
        <a href="/" class="font-heading text-3xl font-semibold tracking-tight text-[var(--text-cream)]">cl1nical</a>
        <h1 class="mt-6 font-heading text-3xl text-[var(--text-cream)]">Create account</h1>
        <p class="mt-2 text-sm text-white/55">Production-style server-rendered auth with secure cookies.</p>
      </div>

      {error && (
        <div class="mb-4 rounded-2xl border border-red-400/20 bg-red-500/10 px-4 py-3 text-sm text-red-200">
          {error}
        </div>
      )}

      <form method="POST" class="space-y-4">
        <label class="block">
          <span class="mb-2 block text-xs font-medium uppercase tracking-[0.18em] text-white/45">Email</span>
          <input
            type="email"
            name="email"
            value={email}
            autocomplete="email"
            required
            class="w-full rounded-2xl border border-white/10 bg-black/25 px-4 py-3 text-sm text-[var(--text-cream)] outline-none transition focus:border-[var(--accent-amber)] focus:ring-2 focus:ring-[var(--accent-amber)]/20"
          />
        </label>

        <label class="block">
          <span class="mb-2 block text-xs font-medium uppercase tracking-[0.18em] text-white/45">Password</span>
          <input
            type="password"
            name="password"
            minlength="8"
            autocomplete="new-password"
            required
            class="w-full rounded-2xl border border-white/10 bg-black/25 px-4 py-3 text-sm text-[var(--text-cream)] outline-none transition focus:border-[var(--accent-amber)] focus:ring-2 focus:ring-[var(--accent-amber)]/20"
          />
        </label>

        <button
          type="submit"
          class="inline-flex w-full items-center justify-center rounded-2xl bg-[var(--accent-amber)] px-4 py-3 text-sm font-semibold text-[var(--text-dark)] transition hover:brightness-105"
        >
          Create Account
        </button>
      </form>

      <p class="mt-6 text-sm text-white/55">
        Already registered?
        <a href="/login" class="ml-1 font-semibold text-[var(--accent-amber)] transition hover:text-white">Sign in</a>
      </p>
    </div>
  </section>
</AppLayout>
