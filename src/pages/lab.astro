---
import Layout from '../layouts/Layout.astro';
import TerminalUI from '../components/Terminal';
---

<Layout title="The Lab | cl1nical">
  <main class="min-h-screen flex flex-col items-center justify-center p-6 bg-[#030303]">
    <div class="mb-8 text-center">
      <h1 class="text-4xl font-black tracking-tighter text-white mb-2 italic">LAB_ENVIRONMENT</h1>
      <p class="text-gray-500 font-mono text-[10px] tracking-[0.3em] uppercase opacity-50">// Session: Active // Port: 443</p>
    </div>

    <div class="w-full max-w-4xl relative scanlines">
      <TerminalUI client:load />
    </div>

    <div class="mt-12 flex gap-8">
        <a href="/" class="text-gray-600 hover:text-red-500 transition-colors font-mono text-xs uppercase tracking-widest border-b border-transparent hover:border-red-500 pb-1">
            Terminate_Session
        </a>
        <a href="/projects" class="text-gray-600 hover:text-purple-500 transition-colors font-mono text-xs uppercase tracking-widest border-b border-transparent hover:border-purple-500 pb-1">
            Jump_to_Projects
        </a>
    </div>
  </main>
</Layout>
