---
import { createServerClient } from '../lib/supabase';

let error = '';

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const email = formData.get('email') as string;
  const password = formData.get('password') as string;

  const supabase = createServerClient({
    get: (name) => Astro.cookies.get(name)?.value,
    set: (name, value, options) => Astro.cookies.set(name, value, options),
    remove: (name, options) => Astro.cookies.delete(name, options),
  });

  const { error: authError } = await supabase.auth.signInWithPassword({ email, password });

  if (authError) {
    error = authError.message;
  } else {
    return Astro.redirect('/dashboard');
  }
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Login — cl1nical</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body class="min-h-screen flex items-center justify-center bg-[#0a0a0a] px-4">
    <div class="w-full max-w-md">
      <div class="text-center mb-8">
        <a href="/" class="font-heading text-3xl font-semibold text-[#F5F0E8] tracking-tight">cl1nical</a>
      </div>

      <div class="bg-[#111111] border border-[#222222] rounded-2xl p-8">
        <h1 class="font-heading text-2xl font-semibold text-[#F5F0E8] mb-2">Welcome back</h1>
        <p class="text-[#8C8882] text-sm mb-6">Sign in to your account</p>

        {error && (
          <div class="mb-4 p-3 bg-red-500/10 border border-red-500/20 rounded-lg text-red-400 text-sm">
            {error}
          </div>
        )}

        <form method="POST" class="space-y-4">
          <div>
            <label for="email" class="block text-sm font-mono text-[#8C8882] mb-2">Email</label>
            <input
              type="email"
              id="email"
              name="email"
              required
              class="w-full px-4 py-3 bg-[#1a1a1a] border border-[#333333] rounded-lg text-[#F5F0E8] font-mono text-sm focus:outline-none focus:border-[#E8A020] transition-colors"
              placeholder="you@example.com"
            />
          </div>

          <div>
            <label for="password" class="block text-sm font-mono text-[#8C8882] mb-2">Password</label>
            <input
              type="password"
              id="password"
              name="password"
              required
              class="w-full px-4 py-3 bg-[#1a1a1a] border border-[#333333] rounded-lg text-[#F5F0E8] font-mono text-sm focus:outline-none focus:border-[#E8A020] transition-colors"
              placeholder="••••••••"
            />
          </div>

          <button
            type="submit"
            class="w-full py-3 bg-[#E8A020] hover:bg-[#d4911a] text-[#0a0a0a] font-mono text-sm font-semibold rounded-lg transition-colors"
          >
            Sign In
          </button>
        </form>

        <div class="mt-6 text-center">
          <p class="text-[#8C8882] text-sm">
            Don't have an account?
            <a href="/register" class="text-[#E8A020] hover:text-[#d4911a] ml-1">Sign up</a>
          </p>
        </div>
      </div>
    </div>
  </body>
</html>
