---
import Layout from '../layouts/Layout.astro';
import { ExternalLink, Github, Layers, Globe } from 'lucide-react';
---

<Layout title="Projects | cl1nical">
  <main class="min-h-screen bg-[#030303] text-white p-6 pt-24">
    <div class="max-w-6xl mx-auto grid grid-cols-1 md:grid-cols-4 gap-4">
      
      <div class="md:col-span-2 md:row-span-2 group relative overflow-hidden rounded-3xl border border-white/10 bg-gradient-to-br from-purple-900/20 to-black p-8">
        <div class="relative z-10">
          <Layers className="text-purple-400 mb-4" size={40} />
          <h2 class="text-3xl font-bold">Cloud Infrastructure</h2>
          <p class="text-gray-400 mt-2">Scalable Kubernetes clusters with automated CI/CD pipelines.</p>
        </div>
        <div class="absolute bottom-0 right-0 p-4 opacity-0 group-hover:opacity-100 transition-opacity">
           <ExternalLink size={24} />
        </div>
      </div>

      <div class="md:col-span-2 p-6 rounded-3xl border border-white/10 bg-white/5 hover:bg-white/10 transition-all">
        <Github className="mb-2" />
        <h3 class="font-bold">Open Source</h3>
        <p class="text-sm text-gray-400">Contributor to 15+ repositories.</p>
      </div>

      <div class="p-6 rounded-3xl border border-white/10 bg-white/5 flex flex-col justify-between">
        <Globe className="text-blue-400" />
        <span class="text-2xl font-bold mt-4">12</span>
        <span class="text-xs text-gray-500 uppercase tracking-widest">Active Domains</span>
      </div>

      <div class="p-6 rounded-3xl border border-purple-500/30 bg-purple-500/10 flex flex-col justify-center items-center text-center">
        <div class="w-12 h-12 rounded-full bg-purple-500 animate-ping absolute opacity-20"></div>
        <span class="font-bold">Hiring?</span>
        <a href="/contact" class="text-xs underline mt-2">Reach out</a>
      </div>
    </div>
  </main>
</Layout>