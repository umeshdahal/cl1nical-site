---
import Layout from '../layouts/Layout.astro';
import { motion } from "framer-motion";
---

<Layout title="Projects | cl1nical">
  <main class="min-h-screen bg-[#030303] text-white p-8 pt-32">
    <div class="max-w-4xl mx-auto">
      <a href="/" class="text-purple-400 hover:text-purple-300 font-mono text-sm">← RETURN_HOME</a>
      <h1 class="text-5xl font-black mt-4 mb-12">DEPLOYED_WORK</h1>

      <div class="grid gap-6">
        {/* Project Card 1 */}
        <div class="group p-6 rounded-2xl border border-white/10 bg-white/5 hover:border-purple-500/50 transition-all cursor-pointer">
          <div class="flex justify-between items-start">
            <div>
              <h3 class="text-xl font-bold group-hover:text-purple-400 transition-colors">Self-Hosted Dashboard</h3>
              <p class="text-gray-400 mt-2">Personal infrastructure monitoring with Grafana and Docker.</p>
            </div>
            <span class="text-[10px] font-mono bg-purple-500/20 text-purple-300 px-2 py-1 rounded">ACTIVE</span>
          </div>
        </div>

        {/* Project Card 2 */}
        <div class="group p-6 rounded-2xl border border-white/10 bg-white/5 hover:border-blue-500/50 transition-all cursor-pointer">
          <div class="flex justify-between items-start">
            <div>
              <h3 class="text-xl font-bold group-hover:text-blue-400 transition-colors">Hardened Linux Kernel</h3>
              <p class="text-gray-400 mt-2">Custom kernel configuration for maximum security and privacy.</p>
            </div>
            <span class="text-[10px] font-mono bg-blue-500/20 text-blue-300 px-2 py-1 rounded">GITHUB</span>
          </div>
        </div>
      </div>
    </div>
  </main>
</Layout>