---
import Layout from '../layouts/Layout.astro';
import { ExternalLink, Github, Layers, Globe, ArrowLeft } from 'lucide-react';
---

<Layout title="Projects | cl1nical">
  <main class="min-h-screen p-6 pt-24 max-w-6xl mx-auto">
    <a href="/" class="inline-flex items-center gap-2 text-gray-500 hover:text-white transition-colors mb-12 font-mono text-sm">
      <ArrowLeft size={16} /> RETURN_TO_BASE
    </a>

    <div class="grid grid-cols-1 md:grid-cols-4 gap-4 auto-rows-[180px]">
      <div class="md:col-span-2 md:row-span-2 group relative overflow-hidden rounded-3xl border border-white/10 bg-gradient-to-br from-purple-900/20 to-black p-8 flex flex-col justify-end">
        <Layers className="text-purple-400 mb-4" size={40} />
        <h2 class="text-3xl font-bold">Neural Infrastructure</h2>
        <p class="text-gray-400 mt-2">Scalable Kubernetes clusters with automated CI/CD pipelines and hardened security.</p>
        <div class="absolute top-6 right-6 p-3 rounded-full bg-white/5 border border-white/10 opacity-0 group-hover:opacity-100 transition-all">
           <ExternalLink size={20} />
        </div>
      </div>

      <div class="md:col-span-2 p-6 rounded-3xl border border-white/10 bg-white/5 hover:bg-white/10 transition-all flex flex-col justify-center">
        <Github className="mb-4 text-gray-400" />
        <h3 class="font-bold text-xl">Open Source Contributor</h3>
        <p class="text-sm text-gray-400">Maintaining critical security patches for Linux kernel modules.</p>
      </div>

      <div class="p-6 rounded-3xl border border-white/10 bg-white/5 flex flex-col justify-between items-center text-center">
        <Globe className="text-blue-400" />
        <span class="text-4xl font-black mt-2">24</span>
        <span class="text-[10px] text-gray-500 uppercase tracking-widest">Global Nodes</span>
      </div>

      <div class="p-6 rounded-3xl border border-purple-500/30 bg-purple-500/10 flex flex-col justify-center items-center text-center group cursor-pointer relative overflow-hidden">
        <div class="w-24 h-24 rounded-full bg-purple-500/20 absolute animate-ping"></div>
        <span class="font-bold relative z-10">HIRE_ME</span>
        <span class="text-[10px] text-purple-300 relative z-10 mt-1">Status: Available</span>
      </div>

      <div class="md:col-span-2 p-6 rounded-3xl border border-white/10 bg-white/5 flex items-center gap-6">
        <div class="h-full aspect-square bg-white/5 rounded-xl border border-white/10 flex items-center justify-center">
            <span class="text-2xl font-bold">01</span>
        </div>
        <div>
            <h4 class="font-bold">Project_Alpha</h4>
            <p class="text-xs text-gray-500">Encrypted messaging protocol built on Rust.</p>
        </div>
      </div>
    </div>
  </main>
</Layout>