---
import Layout from '../layouts/Layout.astro';
import { ArrowLeft } from 'lucide-react';

// TODO: Replace with your new backend API call to fetch user profile
// Since this is a static build, session checks should be handled client-side or via an API route.
---

<Layout title="Profile | cl1nical">
  <main class="min-h-screen p-8 pt-24 max-w-4xl mx-auto">
    <div id="auth-gate" class="hidden">
        <a href="/" class="inline-flex items-center gap-2 text-gray-500 hover:text-white transition-colors mb-12 font-mono text-xs uppercase">
          <ArrowLeft size={14} /> Back_to_Terminal
        </a>

        <div class="p-8 rounded-3xl border border-white/10 bg-white/5 backdrop-blur-xl">
            <h2 class="text-4xl font-black italic mb-8">USER_IDENTITY</h2>
            <div class="space-y-6">
                <div>
                    <label class="block text-[10px] text-gray-500 uppercase tracking-widest mb-2">Email</label>
                    <p id="user-email" class="text-xl font-mono text-purple-400">Loading...</p>
                </div>
                <button id="logout-btn" class="px-6 py-2 border border-red-500/30 text-red-500 text-xs rounded-lg hover:bg-red-500 hover:text-white transition-all">
                    LOGOUT_SESSION
                </button>
            </div>
        </div>
    </div>
    <div id="loading-state" class="text-center py-20">
        <p class="font-mono text-gray-500 animate-pulse">VERIFYING SESSION...</p>
    </div>
  </main>
</Layout>

<script>
  // TODO: Integrate your new Auth API here
  async function checkAuth() {
    // Placeholder: Simulate auth check
    // Replace this with a fetch to your auth endpoint or token validation
    const isAuthenticated = false; // Set to true temporarily to preview the UI
    
    if (!isAuthenticated) {
      // Redirect to login if not authenticated
      window.location.href = '/login';
    } else {
      document.getElementById('auth-gate').classList.remove('hidden');
      document.getElementById('loading-state').classList.add('hidden');
      document.getElementById('user-email').innerText = 'user@example.com'; // Replace with actual email from API
    }
  }

  document.getElementById('logout-btn')?.addEventListener('click', () => {
    // TODO: Call your new Auth API sign-out endpoint
    console.log('Logging out...');
    window.location.href = '/';
  });

  checkAuth();
  document.addEventListener('astro:page-load', checkAuth);
</script>
