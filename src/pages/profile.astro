---
import ProfileEditor from '../components/ProfileEditor';
import AppLayout from '../layouts/AppLayout.astro';
import { getProfileByUser } from '../lib/profile';
import { createServerClient } from '../lib/supabase';

const supabase = createServerClient(Astro.cookies);
const { data: { user } } = await supabase.auth.getUser();

if (!user) {
  return Astro.redirect('/login');
}

const { profile, missingProfilesTable } = await getProfileByUser(supabase, user);
const profileSettings = (profile?.settings ?? {}) as Record<string, unknown>;
---

<AppLayout title="Profile | cl1nical" description="Manage your cl1nical profile">
  <nav class="mx-auto flex w-full max-w-5xl items-center justify-between px-6 py-6">
    <a href="/" class="font-heading text-2xl font-semibold text-[var(--text-cream)]">cl1nical</a>
    <div class="flex items-center gap-5 text-sm text-white/60">
      <a href="/dashboard" class="transition hover:text-white">Dashboard</a>
      <form action="/api/logout" method="POST">
        <button type="submit" class="font-medium text-red-300 transition hover:text-red-200">Logout</button>
      </form>
    </div>
  </nav>

  <main class="mx-auto max-w-3xl px-6 pb-16 pt-4">
    <div class="mb-8 rounded-[32px] border border-white/10 bg-white/6 p-8 shadow-[0_30px_90px_rgba(0,0,0,0.35)] backdrop-blur-xl">
      <p class="text-xs uppercase tracking-[0.22em] text-white/40">Profile</p>
      <h1 class="mt-4 font-heading text-4xl text-[var(--text-cream)]">Account settings</h1>
      <p class="mt-3 text-sm text-white/60">{user.email}</p>
      {missingProfilesTable && (
        <div class="mt-4 rounded-2xl border border-amber-400/20 bg-amber-500/10 px-4 py-3 text-sm text-amber-100">
          Your Supabase project is missing the `public.profiles` table. Apply the latest migration, then profile changes will persist normally.
        </div>
      )}
    </div>

    <ProfileEditor
      client:load
      email={user.email ?? ''}
      displayName={profile?.display_name ?? ''}
      avatarUrl={profile?.avatar_url ?? ''}
      settings={profileSettings}
    />
  </main>
</AppLayout>
