---
import Layout from '../layouts/Layout.astro';
import { supabase } from '../lib/supabase';
import { ShieldCheck, Clock, Mail } from 'lucide-react';

// Fetch real users from your Supabase 'profiles' table
const { data: users, error } = await supabase
  .from('profiles')
  .select('*')
  .order('created_at', { ascending: false });
---

<Layout title="Admin Central | cl1nical">
  <main class="min-h-screen p-8 pt-24 max-w-7xl mx-auto">
    <div class="mb-12">
        <h1 class="text-4xl font-black tracking-tighter flex items-center gap-3 italic">
          <ShieldCheck className="text-purple-500" size={36} /> SYSTEM_ADMIN
        </h1>
        <p class="text-gray-500 font-mono text-xs uppercase tracking-widest mt-2">Accessing User Database...</p>
    </div>

    <div class="overflow-x-auto rounded-2xl border border-white/10 bg-white/5 backdrop-blur-sm">
      <table class="w-full text-left">
        <thead class="bg-white/5 text-[10px] uppercase tracking-widest text-gray-400">
          <tr>
            <th class="p-6">User</th>
            <th class="p-6">Role</th>
            <th class="p-6">Created</th>
            <th class="p-6">Last Active</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-white/5 font-mono text-sm">
          {users?.map(user => (
            <tr class="hover:bg-white/[0.02]">
              <td class="p-6">
                <div class="font-bold">{user.email}</div>
                <div class="text-[10px] text-gray-500 italic">{user.id}</div>
              </td>
              <td class="p-6">
                <span class={`px-2 py-1 rounded-md text-[10px] font-bold ${user.role === 'admin' ? 'bg-purple-500/20 text-purple-400' : 'bg-gray-500/20 text-gray-400'}`}>
                  {user.role}
                </span>
              </td>
              <td class="p-6 text-gray-400 text-xs">{new Date(user.created_at).toLocaleDateString()}</td>
              <td class="p-6 text-purple-400 text-xs">{new Date(user.last_sign_in).toLocaleTimeString()}</td>
            </tr>
          ))}
        </tbody>
      </table>
      {error && <div class="p-10 text-center text-red-500">Error fetching data: {error.message}</div>}
    </div>
  </main>
</Layout>