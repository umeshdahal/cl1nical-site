---
import '../styles/global.css';

interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en" class="bg-[#030303]">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="cl1nical - Digital Portfolio" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body class="antialiased selection:bg-purple-500/30 selection:text-purple-200">
		<slot />
	</body>
</html>

<style is:global>
	/* Custom scrollbar to keep the "cool" vibe */
	::-webkit-scrollbar {
		width: 8px;
	}
	::-webkit-scrollbar-track {
		background: #030303;
	}
	::-webkit-scrollbar-thumb {
		background: #1a1a1a;
		border-radius: 10px;
	}
	::-webkit-scrollbar-thumb:hover {
		background: #252525;
	}
</style>