---
import '../styles/global.css';
import CustomCursor from '../components/effects/CustomCursor';
import ScrollProgressIndicator from '../components/effects/ScrollProgressIndicator';
import SectionCounter from '../components/effects/SectionCounter';
import TopNav from '../components/effects/TopNav';

interface Props {
  title: string;
  showNav?: boolean;
}

const { title, showNav = true } = Astro.props;
---

<!doctype html>
<html lang="en" class="scroll-smooth theme-dark" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="color-scheme" content="dark" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body class="theme-dark" style="--page-bg: var(--bg-dark); --page-fg: var(--text-cream);">
    <div class="noise-overlay"></div>
    <CustomCursor client:only="react" />
    <TopNav client:only="react" />
    {showNav && <ScrollProgressIndicator client:only="react" />}
    {showNav && <SectionCounter client:only="react" />}
    <slot />
  </body>
</html>
